# ── FatherClaw Agent Container ──
# Sandboxed environment with OpenClaw pre-installed.
# Runs headless with bypassPermissions inside Docker isolation.

FROM node:20-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git jq python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install OpenClaw
RUN npm install -g openclaw 2>/dev/null || true

# Use existing non-root 'node' user (UID 1000, built into node:20-slim)
# Claude CLI refuses bypassPermissions under root, so we run as node.
RUN rm -f /usr/bin/su /usr/bin/sudo /bin/su 2>/dev/null || true

# Pre-configured workspace
COPY workspace/ /workspace/
RUN mkdir -p /workspace/output /workspace/.claude \
    && chown -R node:node /workspace

USER node
WORKDIR /workspace

# Default: run OpenClaw with the prompt from env
ENTRYPOINT ["/bin/bash", "-c", "\
  echo \"$AGENT_PROMPT\" | openclaw \
    --print \
    --permission-mode bypassPermissions \
    --output-format text \
    --system-prompt /workspace/CLAUDE.md \
    --no-session-persistence \
    --max-budget-usd ${MAX_BUDGET:-5} \
  "]
