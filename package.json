{
  "name": "fatherclaude",
  "version": "1.0.0",
  "description": "Spawn fully-configured Claude agents in Docker containers with a beautiful web UI",
  "type": "module",
  "keywords": [
    "claude",
    "ai-agent",
    "docker",
    "cli",
    "developer-tools",
    "agentsbooks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roeiba/fatherClaude"
  },
  "homepage": "https://agentsbooks.com",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"tsx --watch server/index.ts\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist-server/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "preview": "vite preview",
    "docker:build": "docker build -f docker/Dockerfile.claude -t fatherclaude-agent docker/"
  },
  "dependencies": {
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "dockerode": "^4.0.10",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
